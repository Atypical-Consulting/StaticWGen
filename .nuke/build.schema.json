{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "BuildDockerImage",
        "BuildWebsite",
        "Clean",
        "CompressOutput",
        "CopyAssets",
        "CopyCss",
        "CopyJsScripts",
        "DeployDockerImage",
        "GenerateBlogIndex",
        "GenerateBuildReport",
        "GenerateFeed",
        "GenerateHtml",
        "GenerateRobotsTxt",
        "GenerateSearchIndex",
        "GenerateSitemap",
        "GenerateTagPages",
        "Init",
        "NewPage",
        "NewPost",
        "OptimizeImages",
        "OptimizeOutput",
        "Validate",
        "ValidateConfig",
        "Watch"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "AnalyticsProvider": {
          "type": "string",
          "description": "Analytics provider: plausible, google, custom, or empty to disable"
        },
        "AnalyticsScriptUrl": {
          "type": "string",
          "description": "Custom analytics script URL"
        },
        "AnalyticsSiteId": {
          "type": "string",
          "description": "Analytics site ID (domain for Plausible, measurement ID for GA4)"
        },
        "Author": {
          "type": "string",
          "description": "Author name"
        },
        "Configuration": {
          "type": "string",
          "description": "Configuration to build - Default is 'Debug' (local) or 'Release' (server)",
          "enum": [
            "Debug",
            "Release"
          ]
        },
        "ContainerName": {
          "type": "string",
          "description": "Docker container name"
        },
        "ContainerPort": {
          "type": "integer",
          "description": "Container port to expose the application",
          "format": "int32"
        },
        "ContinueOnError": {
          "type": "boolean",
          "description": "Continue processing remaining files when one fails"
        },
        "DefaultImageUrl": {
          "type": "string",
          "description": "Default image URL for social sharing"
        },
        "FeedAuthor": {
          "type": "string",
          "description": "Author name for the Atom feed"
        },
        "FeedDescription": {
          "type": "string",
          "description": "Description for the Atom feed"
        },
        "FeedTitle": {
          "type": "string",
          "description": "Title for the Atom feed (defaults to SiteTitle)"
        },
        "FingerprintAssets": {
          "type": "boolean",
          "description": "Enable asset fingerprinting with content hash"
        },
        "GenerateWebP": {
          "type": "boolean",
          "description": "Generate WebP variants of images"
        },
        "HostPort": {
          "type": "integer",
          "description": "Host port to publish the container",
          "format": "int32"
        },
        "ImageMaxWidth": {
          "type": "integer",
          "description": "Maximum image width in pixels",
          "format": "int32"
        },
        "ImageName": {
          "type": "string",
          "description": "Docker image name to build"
        },
        "ImageQuality": {
          "type": "integer",
          "description": "Image compression quality (1-100)",
          "format": "int32"
        },
        "IncludeDrafts": {
          "type": "boolean",
          "description": "Include draft pages in output"
        },
        "MinifyHtml": {
          "type": "boolean",
          "description": "Enable HTML minification"
        },
        "Port": {
          "type": "integer",
          "description": "Port for the development server",
          "format": "int32"
        },
        "SiteBaseUrl": {
          "type": "string",
          "description": "Base URL of the site"
        },
        "SiteTitle": {
          "type": "string",
          "description": "Title of the site"
        },
        "Tags": {
          "type": "string",
          "description": "Tags for the new post (comma-separated)"
        },
        "Theme": {
          "type": "string",
          "description": "Theme name (directory under themes/ or template/ for legacy)"
        },
        "Title": {
          "type": "string",
          "description": "Title for the new content"
        },
        "VersionTag": {
          "type": "string",
          "description": "Docker image version tag"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
